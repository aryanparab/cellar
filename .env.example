# Copy this to .env and fill in your values

# Get your Grok API key from https://console.x.ai
GROK_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: change the model (grok-3-mini is cheapest, grok-3 is most capable)
GROK_MODEL=grok-3-mini

# Optional: point to a local Excel/CSV file instead of fetching from Google Sheets
# WINE_DATA_PATH=./wines.xlsx
